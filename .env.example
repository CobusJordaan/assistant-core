# Ollama connection
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2

# Billing Assistant API (read-only)
BILLING_ASSISTANT_BASE_URL=https://your-billing-host.com/billing
BILLING_ASSISTANT_API_TOKEN=your-token-here
BILLING_ASSISTANT_TIMEOUT=15

# Application
SECRET_KEY=generate-a-random-secret-here
DATABASE_PATH=memory.db

# Internal API auth (billing → assistant-core)
ASSISTANT_CORE_API_TOKEN=generate-a-random-token-here

# System prompt (optional override)
# SYSTEM_PROMPT=You are a helpful AI assistant.
