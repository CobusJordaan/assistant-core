[Unit]
Description=Assistant Core - AI Assistant Backend
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=cj
Group=cj
WorkingDirectory=/opt/assistant-core
ExecStart=/opt/assistant-core/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
EnvironmentFile=/opt/assistant-core/.env

NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/opt/assistant-core

[Install]
WantedBy=multi-user.target
