[Unit]
Description=Text-to-Speech Service (Piper TTS)
After=network.target

[Service]
Type=simple
User=ai-assistant
Group=ai-assistant
WorkingDirectory=/opt/ai-assistant/assistant-core/services/text-to-speech
ExecStart=/opt/ai-assistant/venv/bin/uvicorn app:app --host 0.0.0.0 --port 5400
Restart=always
RestartSec=5
Environment=PIPER_DIR=/opt/piper
Environment=PIPER_MODELS_DIR=/opt/piper/models
Environment=PIPER_DEFAULT_VOICE=en_US-lessac-medium

[Install]
WantedBy=multi-user.target
